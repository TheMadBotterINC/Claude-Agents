#!/usr/bin/env python3
"""
DeepSeek Skill Runner - Run Codex skills with local DeepSeek via Ollama

Usage:
    ./deepseek-skill <skill-name> <directory-to-audit>

Example:
    ./deepseek-skill rails-security ~/projects/myapp
    ./deepseek-skill web-performance ~/projects/frontend
"""

import sys
import os
import json
import subprocess
from pathlib import Path

def load_skill(skill_name):
    """Load a skill's SKILL.md file"""
    skill_path = Path(__file__).parent / "codex" / "skills" / skill_name / "SKILL.md"

    if not skill_path.exists():
        print(f"❌ Skill not found: {skill_name}")
        print(f"   Looking for: {skill_path}")
        available = list((Path(__file__).parent / "codex" / "skills").glob("*/SKILL.md"))
        if available:
            print(f"\n📚 Available skills:")
            for skill in available:
                print(f"   - {skill.parent.name}")
        sys.exit(1)

    return skill_path.read_text()

def run_with_deepseek(skill_content, target_dir, skill_name):
    """Run the skill using DeepSeek via Ollama API"""

    # Build the prompt
    prompt = f"""You are a code auditor using the following skill instructions:

{skill_content}

---

Now, audit the codebase at: {target_dir}

Follow all instructions in the skill document above. Read files, analyze code, and produce the requested report.
"""

    print(f"🚀 Running {skill_name} with DeepSeek R1 70B...")
    print(f"📁 Target: {target_dir}\n")

    # Prepare the request for Ollama API
    request = {
        "model": "deepseek-r1:70b",
        "messages": [
            {
                "role": "system",
                "content": "You are an expert code auditor with deep knowledge of security, performance, and best practices. You have full access to read files and analyze codebases."
            },
            {
                "role": "user",
                "content": prompt
            }
        ],
        "stream": True
    }

    # Call Ollama API
    try:
        process = subprocess.Popen(
            ["curl", "-s", "-X", "POST", "http://localhost:11434/api/chat",
             "-H", "Content-Type: application/json",
             "-d", json.dumps(request)],
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True
        )

        # Stream the response
        for line in process.stdout:
            if line.strip():
                try:
                    data = json.loads(line)
                    if "message" in data and "content" in data["message"]:
                        content = data["message"]["content"]
                        print(content, end="", flush=True)
                except json.JSONDecodeError:
                    pass

        print("\n\n✅ Analysis complete!")

    except Exception as e:
        print(f"❌ Error: {e}")
        sys.exit(1)

def main():
    if len(sys.argv) < 3:
        print(__doc__)
        sys.exit(1)

    skill_name = sys.argv[1]
    target_dir = os.path.abspath(sys.argv[2])

    if not os.path.exists(target_dir):
        print(f"❌ Directory not found: {target_dir}")
        sys.exit(1)

    # Load the skill
    skill_content = load_skill(skill_name)

    # Run with DeepSeek
    run_with_deepseek(skill_content, target_dir, skill_name)

if __name__ == "__main__":
    main()
